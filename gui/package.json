{
  "name": "gui",
  "productName": "Screen Analysis",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron:dev\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "package:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "keytar": "^7.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.screenanalysis.desktop",
    "productName": "Screen Analysis",
    "artifactName": "${productName}.exe",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.cjs",
      "overlay.html",
      "overlay.js"
    ],
    "extraResources": [
      {
        "from": "../engine/dist/engine.exe",
        "to": "engine/engine.exe"
      }
    ],
    "win": {
      "icon": "icon.ico",
      "executableName": "Screen Analysis",
      "target": "nsis"
    },
    "nsis": {
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  }
}
